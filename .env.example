# ─────────────────────────────────────────────────────────────
# Configuration (template — copy to .env and adjust)
# ─────────────────────────────────────────────────────────────
# How config is loaded:
#   • The Lambdas read ONLY two real env vars: CONFIG_PATH and LOG_LEVEL.
#   • CONFIG_PATH points to a JSON config file (s3://bucket/key, or a local path).
#   • Everything else below lives INSIDE that JSON file — listed here as a
#     reference of all the values you need to fill in.
#
# Data source: Open-Meteo (https://open-meteo.com) — free, NO API KEY needed.

CONFIG_PATH=s3://my-config-bucket/config/weather_producer.json
LOG_LEVEL=INFO

# ── weather_producer config keys ──
QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/weather-queue
OPEN_METEO_API_KEY=
UNITS=metric
HTTP_TIMEOUT=10
# LOCATIONS is a JSON list in the config file, e.g.:
#   [{ "city": "Tunis", "country": "TN", "latitude": 36.8065, "longitude": 10.1815 }]

# ── stream_processor config keys ──
# Object names auto-generated: raw/dt=YYYY-MM-DD/hour=HH/<timestamp>-<uuid>.json
OUTPUT_BUCKET=my-data-lake-bucket
RAW_PREFIX=raw/
