# ─────────────────────────────────────────────────────────────
# Configuration (template — copy to .env and adjust)
# ─────────────────────────────────────────────────────────────
# How config is loaded:
#   • The Lambdas read ONLY two real env vars: CONFIG_PATH and LOG_LEVEL.
#   • CONFIG_PATH points to a JSON config file (s3://bucket/key, or a local path).
#   • Everything else below lives INSIDE that JSON file — listed here as a
#     reference of all the values you need to fill in.
#
# Data source: product/event feed for e-commerce analytics.

CONFIG_PATH=
LOG_LEVEL=INFO

# ── ecommerce_producer config keys ──
QUEUE_URL=
QUEUE_NAME=
CHANNEL=web
# PRODUCTS is a JSON list in the config file, e.g.:
#   [{ "product_id": "sku-1001", "sku": "SKU-1001", "name": "Wireless Mouse", "price": 49.99 }]

# ── stream_processor config keys ──
# Object names auto-generated: raw/dt=YYYY-MM-DD/hour=HH/<timestamp>-<uuid>.json


# ── deployment / Terraform output values ──
QUEUE_ARN=
LAMBDA_PRODUCER_NAME=
LAMBDA_PROCESSOR_NAME=
GLUE_JOB_NAME=
ECOMMERCE_API_URL=https://fakestoreapi.com/products
OUTPUT_BUCKET=
RAW_BUCKET=raw/
PROCESSED_BUCKET=processed/

# ── glue processing job config keys ──
# Use the same CONFIG_PATH file for the raw input prefix and processed output prefix.RAW_PREFIX=raw/

