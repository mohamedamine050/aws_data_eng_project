# ─────────────────────────────────────────────────────────────
# Configuration (template — copy to .env and adjust)
# ─────────────────────────────────────────────────────────────
# How config is loaded:
#   • The Lambdas read ONLY two real env vars: CONFIG_PATH and LOG_LEVEL.
#   • CONFIG_PATH points to a JSON config file (s3://bucket/key, or a local path).
#   • Everything else below lives INSIDE that JSON file (config/*.json) — it is
#     listed here as a single reference of all the values you need to fill in.
#
# Data source: Open-Meteo (https://open-meteo.com) — free, NO API KEY needed.

# ── Real Lambda env vars ─────────────────────────────────────
CONFIG_PATH=s3://my-config-bucket/config/weather_producer.json
LOG_LEVEL=INFO

# ── weather_producer config keys (config/weather_producer.json) ──
# API endpoint (hardcoded in code; shown for reference):
#   https://api.open-meteo.com/v1/forecast
KINESIS_STREAM_NAME=rt-weather-analytics-dev-stream
OPEN_METEO_API_KEY=
UNITS=metric
HTTP_TIMEOUT=10
# LOCATIONS is a JSON list in the config file, e.g.:
#   [{ "city": "Tunis", "country": "TN", "latitude": 36.8065, "longitude": 10.1815 }]

# ── stream_processor config keys (config/stream_processor.json) ──
# Output S3 bucket (the data-lake) + key prefix. Object names are generated
# automatically: raw/dt=YYYY-MM-DD/hour=HH/<shard>-<timestamp>.json
OUTPUT_BUCKET=my-data-lake-bucket
RAW_PREFIX=raw/
